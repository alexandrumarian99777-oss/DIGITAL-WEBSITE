<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href="/" aria-label="AM Digital Growth acasă">
      <img src="/images/logo6.png" alt="Logo AM Digital Growth" width="150" height="100">
      <span><%= content.business.shortName %></span>
    </a>

    <button class="hamburger" type="button" id="hamburgerBtn" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-menu" id="navMenu">
      <nav class="nav-links" aria-label="Navigație principală">
        <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">
          Acasă
        </a>

        <a href="/despre" class="<%= currentPath === '/despre' ? 'active' : '' %>">
          Despre
        </a>

        <div class="nav-dropdown">
          <button class="dropdown-toggle" type="button" aria-expanded="false">
            Servicii
            <span>▾</span>
          </button>

          <div class="dropdown-menu">
            <a href="/servicii">Site-uri și sisteme web</a>
            <a href="/mentenanta">Mentenanță lunară</a>
            <a href="/campanii-publicitare">Campanii publicitare</a>
            <a href="/#faq">Întrebări frecvente</a>
          </div>
        </div>

        <a href="/proiecte" class="<%= currentPath === '/proiecte' ? 'active' : '' %>">
          Proiecte
        </a>

        <a href="/blog" class="<%= currentPath.startsWith('/blog') ? 'active' : '' %>">
          Blog
        </a>

        <a href="/contact" class="<%= currentPath === '/contact' ? 'active' : '' %>">
          Contact
        </a>
      </nav>

      <div class="nav-actions">
        <a class="btn btn-primary nav-cta" href="/contact#formular">
          Demo gratuit
        </a>

        <a class="btn btn-secondary nav-call" href="tel:<%= content.business.phone.replace(/\s+/g, '') %>">
          Sună acum
        </a>
      </div>

      <div class="language-switcher notranslate" translate="no">
        <select id="languageSelect" onchange="changeLanguage(this.value)" aria-label="Schimbă limba">
          <option value="ro">RO</option>
          <option value="en">EN</option>
          <option value="it">IT</option>
          <option value="fr">FR</option>
          <option value="de">DE</option>
          <option value="es">ES</option>
        </select>
      </div>
    </div>

    <div id="google_translate_element" style="display: none;"></div>
  </div>
</header>