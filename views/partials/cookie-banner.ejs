<div class="cookie-banner" id="cookieBanner" aria-live="polite">
    <div class="cookie-content">
        <h3>Setări cookie</h3>

        <p>
            Folosim cookie-uri necesare pentru funcționarea site-ului. Cu acordul tău, putem folosi și cookie-uri pentru
            analiză și marketing.
        </p>

        <div class="cookie-actions">
            <button class="btn btn-secondary" type="button" id="rejectCookies">
                Refuz
            </button>

            <button class="btn btn-secondary" type="button" id="manageCookies">
                Setări
            </button>

            <button class="btn btn-primary" type="button" id="acceptCookies">
                Accept
            </button>
        </div>

        <div class="cookie-settings" id="cookieSettings">
            <label class="check">
                <input type="checkbox" checked disabled>
                Cookie-uri necesare
            </label>

            <label class="check">
                <input type="checkbox" id="analyticsCookies">
                Cookie-uri analiză
            </label>

            <label class="check">
                <input type="checkbox" id="marketingCookies">
                Cookie-uri marketing
            </label>

            <button class="btn btn-primary" type="button" id="saveCookieSettings">
                Salvează preferințele
            </button>

            <a href="/setari-cookie" class="cookie-link">
                Află mai multe
            </a>
        </div>
    </div>
</div>