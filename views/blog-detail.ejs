<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main>
  <article class="section blog-detail">
    <div class="container narrow">
      <p class="eyebrow">Blog</p>
      <h1><%= post.title %></h1>
      <p class="hero-text"><%= post.excerpt %></p>
      <% if (post.coverImage) { %>
        <img class="blog-cover" src="<%= post.coverImage %>" alt="<%= post.coverAlt || post.title %>" loading="eager">
      <% } %>
      <div class="article-content">
        <% post.content.split('\n').forEach((paragraph) => { %>
          <% if (paragraph.trim()) { %>
            <p><%= paragraph %></p>
          <% } %>
        <% }) %>
      </div>
    </div>
  </article>
</main>

<%- include('partials/footer') %>
