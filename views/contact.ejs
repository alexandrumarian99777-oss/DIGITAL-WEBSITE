<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main>
  <section class="page-hero section">
    <div class="container narrow">
      <p class="eyebrow">Contact</p>
      <h1>Programează o prezentare gratuită pentru site-ul, sistemul sau campania ta.</h1>
      <p>
        Completează formularul. Spune ce afacere ai, ce problemă vrei să rezolvi
        și ce pachet te interesează.
      </p>
    </div>
  </section>

  <section id="formular" class="section">
    <div class="container contact-grid">
      <form class="lead-form" method="POST" action="/leads">
        <h2>Trimite cererea</h2>

        <div class="form-grid two">
          <input name="name" placeholder="Nume" required>
          <input name="phone" placeholder="Telefon" required>
          <input name="email" type="email" placeholder="Email" required>
          <input name="businessName" placeholder="Numele afacerii">
          <input name="businessType" placeholder="Tip afacere: salon, restaurant, construcții...">
          <input name="website" placeholder="Site / Facebook / Instagram">
        </div>

        <select name="packageInterest" required>
          <option value="">
            Alege serviciul care te interesează
          </option>

          <optgroup label="Site-uri și sisteme web">
            <option value="exist-online">
              Exist Online - de la 299 €
            </option>

            <option value="castig-incredere">
              Câștig Încredere - de la 549 €
            </option>

            <option value="aduc-clienti">
              Aduc Clienți - de la 1.400 €
            </option>

            <option value="pagina-reclame">
              Pagină dedicată pentru reclame - de la 250 € la 500 €
            </option>
          </optgroup>

          <optgroup label="Mentenanță lunară">
            <option value="mentenanta-simpla">
              Mentenanță Simplă - 49 €/lună
            </option>

            <option value="mentenanta-standard">
              Mentenanță Standard - 99 €/lună
            </option>

            <option value="mentenanta-pro">
              Mentenanță Pro - 179 €/lună
            </option>
          </optgroup>

          <optgroup label="Campanii publicitare">
            <option value="promovare-inceput">
              Promovare de Început - de la 199 €/lună
            </option>

            <option value="promovare-locala">
              Promovare Locală - de la 349 €/lună
            </option>

            <option value="promovare-crestere">
              Promovare pentru Creștere - de la 599 €/lună
            </option>

            <option value="configurare-campanie">
              Configurare campanie - de la 150 € la 250 €
            </option>
          </optgroup>

          <optgroup label="Consultanță și alte solicitări">
            <option value="audit-gratuit">
              Audit gratuit pentru site sau prezența online
            </option>

            <option value="consultanta-gratuita">
              Consultație gratuită
            </option>

            <option value="pachet-personalizat">
              Pachet personalizat
            </option>

            <option value="recomandare">
              Nu știu ce să aleg și am nevoie de recomandare
            </option>
          </optgroup>
        </select>

        <textarea name="message" placeholder="Ce vrei să rezolvăm pentru afacerea ta?" required></textarea>

        <label class="form-consent">
          <input type="checkbox" name="acceptTerms" value="yes" required>
          <span>
            Prin completarea acestui formular, ești de acord cu
            <a href="/termeni-si-conditii" target="_blank">Termenii și Condițiile</a>.
          </span>
        </label>

        <button class="btn btn-primary" type="submit">Trimite cererea</button>
      </form>

      <aside class="contact-card">
        <h2>Detalii contact</h2>

        <p><strong>Telefon:</strong> <%= content.business.phone %></p>
        <p><strong>Email:</strong> <%= content.business.email %></p>
        <p><strong>Locație:</strong> <%= content.business.address %></p>

        <a class="btn btn-secondary full" href="<%= content.business.whatsapp %>" target="_blank" rel="noopener">
          Scrie pe WhatsApp
        </a>

        <p class="small-note">
          Domeniul standard este inclus în pachetele de site. Domeniile premium,
          găzduirea premium, emailul profesional, aplicațiile terțe și bugetul de reclame
          se taxează separat.
        </p>
      </aside>
    </div>
  </section>
</main>

<%- include('partials/footer') %>