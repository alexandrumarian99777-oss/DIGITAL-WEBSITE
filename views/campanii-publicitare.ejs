<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main>
    <section class="page-hero section">
        <div class="container narrow">
            <p class="eyebrow">Campanii publicitare</p>
            <h1>Promovare online pentru afaceri locale care vor mai multe cereri</h1>
            <p>
                Pregătim și administrăm campanii pe Facebook, Instagram și Google.
                Bugetul efectiv de reclame este separat și se plătește direct către platformă.
            </p>
        </div>
    </section>

    <section class="section soft-section ads-section">
        <div class="container ads-alert">
            <strong>Buget separat:</strong>
            <span>
                Prețurile de mai jos reprezintă taxa de configurare și administrare.
                Bugetul efectiv de reclame nu este inclus.
            </span>
        </div>

        <div class="container ads-offer-grid">
            <article class="ads-plan-card">
                <div class="ads-plan-top">
                    <span class="ads-badge">Promovare Simplă</span>
                    <h3>Promovare de Început</h3>
                    <p>Pentru afaceri mici care vor să testeze reclame local.</p>
                </div>

                <div class="ads-price">
                    <span>De la</span>
                    <strong>€199</strong>
                    <em>/ lună</em>
                </div>

                <ul class="ads-list">
                    <li>1 platformă: reclame pe Facebook, Instagram sau Google</li>
                    <li>1 campanie principală</li>
                    <li>Configurare de bază</li>
                    <li>Texte simple pentru reclame</li>
                    <li>Direcționare locală</li>
                    <li>Verificare săptămânală</li>
                    <li>Raport lunar simplu</li>
                </ul>

                <div class="ads-recommendation">
                    Buget reclame recomandat: <strong>€150-€300/lună</strong>
                </div>

                <a class="btn btn-primary full" href="/contact#formular">Vreau promovare de început</a>
            </article>

            <article class="ads-plan-card ads-featured">
                <div class="ads-plan-top">
                    <span class="ads-badge">Recomandat</span>
                    <h3>Promovare Locală</h3>
                    <p>Pentru afaceri care vor campanii mai clare și cereri mai constante.</p>
                </div>

                <div class="ads-price">
                    <span>De la</span>
                    <strong>€349</strong>
                    <em>/ lună</em>
                </div>

                <ul class="ads-list">
                    <li>Reclame pe Facebook, Instagram sau Google</li>
                    <li>2 campanii active</li>
                    <li>2-4 reclame/teste</li>
                    <li>Texte pentru reclame</li>
                    <li>Optimizare săptămânală</li>
                    <li>Urmărire rezultate de bază</li>
                    <li>Raport lunar cu recomandări</li>
                </ul>

                <div class="ads-recommendation">
                    Buget reclame recomandat: <strong>€300-€800/lună</strong>
                </div>

                <a class="btn btn-primary full" href="/contact#formular">Vreau promovare locală</a>
            </article>

            <article class="ads-plan-card">
                <div class="ads-plan-top">
                    <span class="ads-badge">Creștere</span>
                    <h3>Campanii de Creștere</h3>
                    <p>Pentru afaceri care au deja site bun și vor să testeze mai serios.</p>
                </div>

                <div class="ads-price">
                    <span>De la</span>
                    <strong>€599</strong>
                    <em>/ lună</em>
                </div>

                <ul class="ads-list">
                    <li>4 campanii active</li>
                    <li>Reclame pe Facebook, Instagram și Google</li>
                    <li>12 reclame/teste</li>
                    <li>Campanii separate pe obiective</li>
                    <li>Testare audiențe și mesaje</li>
                    <li>Optimizare pentru cereri</li>
                    <li>Recomandări pentru pagină dedicată</li>
                    <li>Raport lunar mai detaliat</li>
                    <li>Traseu de conversie</li>
                </ul>

                <div class="ads-recommendation">
                    Buget reclame recomandat: <strong>€800-€2.000/lună</strong>
                </div>

                <a class="btn btn-primary full" href="/contact#formular">Vreau campanii de creștere</a>
            </article>
        </div>

        <div class="container ads-small-grid">
            <article class="ads-small-card">
                <h3>Configurare campanie</h3>
                <p>
                    Pentru campanii noi, configurarea pornește de la <strong>€150-€250</strong>,
                    în funcție de platformă și complexitate.
                </p>
            </article>

            <article class="ads-small-card">
                <h3>Pagină dedicată pentru reclame</h3>
                <p>
                    Dacă nu există o pagină clară pentru trafic, putem crea una separat,
                    de la <strong>€250-€500</strong>.
                </p>
            </article>

            <article class="ads-small-card">
                <h3>Fără promisiuni false</h3>
                <p>
                    Nu garantăm vânzări sau rezultate fixe. Construim campanii clare,
                    pagini relevante și optimizăm în timp.
                </p>
            </article>
        </div>
    </section>
</main>

<%- include('partials/footer') %>