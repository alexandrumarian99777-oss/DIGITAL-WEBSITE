<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main>
  <!-- HERO -->
  <section class="hero section hero-bg-centered">
    <div class="container hero-bg-content">
      <div class="hero-copy hero-centered-text">
        <p class="eyebrow">
          Website-uri și sisteme digitale pentru afaceri locale
        </p>

        <h1>
          Transformăm vizitatorii în cereri, programări și clienți.
        </h1>

        <p class="hero-text">
          Construim website-uri rapide, formulare de contact, sisteme de
          programări și panouri de administrare care prezintă clar afacerea
          și simplifică procesul de atragere a clienților.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/contact#formular">
            Programează o consultație gratuită
          </a>

          <a class="btn btn-secondary" href="#proiecte">
            Vezi exemplele
          </a>
        </div>

        <p class="domain-note">
          Domeniu standard inclus în pachetele de website. Domeniile premium,
          găzduirea premium, emailul profesional și aplicațiile terțe se
          taxează separat.
        </p>
      </div>
    </div>
  </section>

  <!-- REPERE RAPIDE -->
  <section class="stats-section" aria-label="Detalii despre colaborare">
    <div class="container stats-grid">
      <div class="stat-card">
        <strong>30 de minute</strong>
        <span>Consultație inițială</span>
      </div>

      <div class="stat-card">
        <strong>14–21 de zile</strong>
        <span>Termen mediu de lansare</span>
      </div>

      <div class="stat-card">
        <strong>Gratuit</strong>
        <span>Analiza inițială</span>
      </div>
    </div>
  </section>

  <!-- CONCEPTE DEMONSTRATIVE -->
  <section id="proiecte" class="section projects-section">
    <div class="container section-heading">
      <p class="eyebrow">Concepte demonstrative</p>

      <h2>
        Exemple de website-uri pe care le putem construi
      </h2>

      <p>
        Aceste concepte prezintă direcții de design, structură și
        funcționalități disponibile pentru diferite tipuri de afaceri.
        Nu sunt prezentate drept proiecte comerciale livrate unor clienți.
      </p>
    </div>

    <div class="container projects-grid">
      <!-- SALON -->
      <article class="project-card">
        <div class="project-image-wrap">
          <img src="/images/projects/salon.png" alt="Concept demonstrativ de website pentru salon de înfrumusețare"
            class="project-image zoomable-image" data-full-image="/images/projects/salon.png" loading="lazy"
            tabindex="0" role="button" aria-label="Deschide conceptul de website pentru salon">

          <span class="project-badge">
            Concept pentru salon
          </span>
        </div>

        <div class="project-content">
          <div class="project-meta">
            <span>Design elegant</span>
            <span>Responsive</span>
            <span>Programări online</span>
          </div>

          <h3>
            Salon Beauty — website de prezentare
          </h3>

          <p>
            Structură modernă pentru un salon de înfrumusețare, cu servicii
            prezentate clar, imagini elegante și acces rapid la programări
            și informațiile de contact.
          </p>

          <div class="project-actions">
            <a class="btn btn-primary" href="/contact#formular">
              Vreau un website similar
            </a>

            <button class="btn btn-secondary project-preview-button" type="button"
              data-preview-target="/images/projects/salon.png" data-preview-alt="Concept demonstrativ pentru salon">
              Vezi imaginea completă
            </button>
          </div>
        </div>
      </article>

      <!-- RESTAURANT -->
      <article class="project-card">
        <div class="project-image-wrap">
          <img src="/images/projects/restaurant.png" alt="Concept demonstrativ de website premium pentru restaurant"
            class="project-image zoomable-image" data-full-image="/images/projects/restaurant.png" loading="lazy"
            tabindex="0" role="button" aria-label="Deschide conceptul de website pentru restaurant">

          <span class="project-badge">
            Concept pentru restaurant
          </span>
        </div>

        <div class="project-content">
          <div class="project-meta">
            <span>Design premium</span>
            <span>Meniu online</span>
            <span>Rezervări rapide</span>
          </div>

          <h3>
            Maison Noir — website premium pentru restaurant
          </h3>

          <p>
            Concept elegant pentru un restaurant premium, cu prezentarea
            meniului, imagini gastronomice de impact și acces rapid la
            rezervări și contact.
          </p>

          <div class="project-actions">
            <a class="btn btn-primary" href="/contact#formular">
              Vreau un website similar
            </a>

            <button class="btn btn-secondary project-preview-button" type="button"
              data-preview-target="/images/projects/restaurant.png"
              data-preview-alt="Concept demonstrativ pentru restaurant">
              Vezi imaginea completă
            </button>
          </div>
        </div>
      </article>

      <!-- IMOBILIARE -->
      <article class="project-card project-card-real-estate">
        <div class="project-image-wrap">
          <img src="/images/projects/imobiliare.png"
            alt="Concept demonstrativ de website premium pentru agenție imobiliară" class="project-image zoomable-image"
            data-full-image="/images/projects/imobiliare.png" loading="lazy" tabindex="0" role="button"
            aria-label="Deschide conceptul de website pentru agenție imobiliară">

          <span class="project-badge">
            Concept pentru imobiliare
          </span>
        </div>

        <div class="project-content">
          <div class="project-meta">
            <span>Design premium</span>
            <span>Listări proprietăți</span>
            <span>Generare de lead-uri</span>
          </div>

          <h3>
            Greenwich Realty — website pentru agenție imobiliară
          </h3>

          <p>
            Concept pentru o agenție imobiliară, cu proprietăți prezentate
            profesional, filtre de căutare, profil de agent și formulare
            clare pentru programarea consultațiilor.
          </p>

          <div class="project-actions">
            <a class="btn btn-primary" href="/contact#formular">
              Vreau un website similar
            </a>

            <button class="btn btn-secondary project-preview-button" type="button"
              data-preview-target="/images/projects/imobiliare.png"
              data-preview-alt="Concept demonstrativ pentru agenție imobiliară">
              Vezi imaginea completă
            </button>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- CE REZOLVĂM -->
  <section id="ce-rezolam" class="section">
    <div class="container section-heading">
      <p class="eyebrow">Ce rezolvăm</p>

      <h2>
        Un website construit pentru acțiune, nu doar pentru aspect
      </h2>

      <p>
        Structurăm informația, formularele și punctele de contact astfel
        încât vizitatorul să înțeleagă rapid oferta și următorul pas.
      </p>
    </div>

    <div class="container cards-grid three">
      <% content.fixes.slice(0, 6).forEach((item) => { %>
      <article class="service-card equal-card">
        <h3><%= item.title %></h3>
        <p><%= item.text %></p>
      </article>
      <% }) %>
    </div>
  </section>

  <!-- PACHETE PRINCIPALE -->
  <section id="pachete" class="section soft-section">
    <div class="container section-heading">
      <p class="eyebrow">Pachete principale</p>

      <h2>
        Alege nivelul potrivit pentru etapa actuală a afacerii
      </h2>

      <p>
        Pe homepage afișăm variantele principale. Lista completă de
        funcționalități, limitări și servicii opționale este disponibilă
        pe pagina de servicii.
      </p>
    </div>

    <div class="container-bgg pricing-grid compact-pricing-grid">
      <% content.packages.forEach((pkg) => { %>
      <article class="pricing-card equal-card <%= pkg.featured ? 'featured' : '' %>">
        <span class="pricing-tag">
          <%= pkg.tag %>
        </span>

        <h3>
          <%= pkg.name %>
        </h3>

        <div class="price">
          <%= pkg.price %>
        </div>

        <p class="intro-price">
          <%= pkg.introPrice %>
        </p>

        <p>
          <%= pkg.bestFor %>
        </p>

        <p class="pages">
          <%= pkg.pages %>
        </p>

        <h4>Include, pe scurt</h4>

        <ul>
          <% pkg.included.slice(0, 4).forEach((feature) => { %>
          <li>
            <%= feature %>
          </li>
          <% }) %>
        </ul>

        <a class="btn btn-primary full" href="/servicii">
          Vezi detaliile pachetului
        </a>
      </article>
      <% }) %>
    </div>

    <div class="container center-button">
      <a class="btn btn-secondary" href="/servicii">
        Compară toate serviciile și funcționalitățile
      </a>
    </div>
  </section>

  <!-- SOLUȚIE PERSONALIZATĂ -->
  <section class="section">
    <div class="container final-card">
      <p class="eyebrow">Ai nevoie de mai mult?</p>

      <h2>
        Soluție personalizată pentru fluxuri mai complexe
      </h2>

      <p>
        Pentru proiecte care includ programări avansate, roluri de
        utilizator, panou de administrare, blog, recenzii, plăți sau
        integrări externe, stabilim separat arhitectura și bugetul.
      </p>

      <a class="btn btn-primary cta-small-btn" href="/contact#formular">
        Discută proiectul
      </a>
    </div>
  </section>

  <!-- SERVICII DUPĂ LANSARE -->
  <section class="section soft-section">
    <div class="container section-heading">
      <p class="eyebrow">După lansare</p>

      <h2>
        Mentenanță și promovare, fără să aglomerăm pachetul inițial
      </h2>

      <p>
        Alegi separat serviciile recurente de care afacerea are nevoie
        după publicare.
      </p>
    </div>

    <div class="container home-service-grid">
      <article class="home-service-card">
        <span class="pricing-tag">
          De la 49 €/lună
        </span>

        <h3>Mentenanță lunară</h3>

        <p>
          Verificări, backup, suport și modificări simple pentru un
          website actualizat și funcțional.
        </p>

        <a class="btn btn-secondary full" href="/mentenanta">
          Vezi mentenanța
        </a>
      </article>

      <article class="home-service-card">
        <span class="pricing-tag">
          De la 199 €/lună
        </span>

        <h3>Campanii publicitare</h3>

        <p>
          Administrare Facebook, Instagram și Google Ads. Bugetul efectiv
          de publicitate se plătește separat platformelor.
        </p>

        <a class="btn btn-secondary full" href="/campanii-publicitare">
          Vezi promovarea
        </a>
      </article>
    </div>
  </section>

  <!-- PROCES -->
  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Cum lucrăm</p>

      <h2>
        Proces clar, cu responsabilități și termene definite
      </h2>

      <p>
        Stabilim ce trebuie construit, ce materiale sunt necesare și ce
        trebuie aprobat înainte să începem dezvoltarea.
      </p>
    </div>

    <div class="container cards-grid three">
      <% content.process.forEach((item) => { %>
      <article class="process-card equal-card">
        <span class="step">
          <%= item.step %>
        </span>

        <h3>
          <%= item.title %>
        </h3>

        <p>
          <%= item.text %>
        </p>
      </article>
      <% }) %>
    </div>
  </section>

  <!-- CE PRIMEȘTI -->
  <section class="section soft-section">
    <div class="container section-heading">
      <p class="eyebrow">Colaborare</p>

      <h2>
        Ce primești când lucrăm împreună
      </h2>

      <p>
        Fără promisiuni inventate și fără rezultate garantate. Primești
        un proces controlat și un produs livrabil clar.
      </p>
    </div>

    <div class="container cards-grid three">
      <article class="service-card equal-card">
        <h3>Comunicare directă</h3>

        <p>
          Discuți direct cu persoana care construiește proiectul, fără
          intermediari și fără pierderi de informație.
        </p>
      </article>

      <article class="service-card equal-card">
        <h3>Livrabile definite</h3>

        <p>
          Paginile, funcționalitățile, reviziile și limitele proiectului
          sunt stabilite înainte de dezvoltare.
        </p>
      </article>

      <article class="service-card equal-card">
        <h3>Predare și suport</h3>

        <p>
          Verificăm formularele și funcțiile importante, apoi primești
          instrucțiuni pentru administrarea elementelor incluse.
        </p>
      </article>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="section faq-section">
    <div class="container section-heading">
      <p class="eyebrow">Întrebări frecvente</p>

      <h2>
        Ce trebuie clarificat înainte să începem
      </h2>

      <p>
        Răspunsuri directe despre termene, domeniu, publicitate și
        rezultate.
      </p>
    </div>

    <div class="container faq-wrap">
      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>
            Cât durează realizarea unui website?
          </span>

          <strong>+</strong>
        </button>

        <div class="faq-answer">
          <p>
            Un website standard poate fi lansat în aproximativ 14–21 de
            zile, după primirea materialelor și aprobarea structurii.
            Proiectele cu funcționalități personalizate pot necesita mai
            mult timp.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>
            Domeniul este inclus?
          </span>

          <strong>+</strong>
        </button>

        <div class="faq-answer">
          <p>
            Un domeniu standard este inclus în prețul pachetului pentru primul an, în limita unui cost de maximum 20
            EUR, inclusiv TVA. Dacă prețul domeniului depășește această limită, costul integral al domeniului va fi
            suportat de Client, după acceptarea prealabilă. Reînnoirea domeniului după primul an este achitată separat
            de Client.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>
            Campaniile includ bugetul de publicitate?
          </span>

          <strong>+</strong>
        </button>

        <div class="faq-answer">
          <p>
            Nu. Serviciul de administrare este separat de bugetul plătit
            către Facebook, Instagram sau Google.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>
            Garantezi vânzări sau un anumit număr de clienți?
          </span>

          <strong>+</strong>
        </button>

        <div class="faq-answer">
          <p>
            Nu. Rezultatele depind de ofertă, piață, prețuri, reputație,
            buget, concurență și modul în care sunt gestionate cererile
            primite.
          </p>
        </div>
      </div>
    </div>

    <div class="container center-button">
      <a class="btn btn-secondary" href="/servicii">
        Vezi informațiile complete
      </a>
    </div>
  </section>

  <!-- BLOG -->
  <% if (posts && posts.length) { %>
  <section class="section soft-section">
    <div class="container section-heading">
      <p class="eyebrow">Resurse</p>

      <h2>
        Articole utile pentru afaceri locale
      </h2>
    </div>

    <div class="container blog-grid">
      <% posts.slice(0, 3).forEach((post) => { %>
      <article class="blog-card equal-card">
        <% if (post.coverImage) { %>
        <img src="<%= post.coverImage %>" alt="<%= post.coverAlt || post.title %>" loading="lazy">
        <% } %>

        <div>
          <h3>
            <%= post.title %>
          </h3>

          <p class="blog-card-excerpt">
            <%= post.excerpt %>
          </p>
        </div>

        <a class="card-link" href="/blog/<%= post.slug %>">
          Citește articolul
        </a>
      </article>
      <% }) %>
    </div>

    <div class="container center-button">
      <a class="btn btn-secondary" href="/blog">
        Vezi toate articolele
      </a>
    </div>
  </section>
  <% } %>

  <!-- CTA FINAL -->
  <section class="section final-cta">
    <div class="container final-card">
      <p class="eyebrow">Următorul pas</p>

      <h2>
        Ai nevoie de un website clar și ușor de administrat?
      </h2>

      <p>
        Trimite informațiile de bază despre afacere, serviciile oferite
        și obiectivul principal. Stabilim apoi dacă proiectul are sens
        și ce variantă este potrivită.
      </p>

      <a class="btn btn-primary cta-small-btn" href="/contact#formular">
        Programează consultația
      </a>
    </div>
  </section>
</main>

<!-- PREVIEW PROIECT -->
<div class="image-modal" id="imageModal" aria-hidden="true" role="dialog" aria-modal="true"
  aria-label="Previzualizare proiect">
  <button class="image-modal-close" id="imageModalClose" type="button" aria-label="Închide imaginea">
    &times;
  </button>

  <div class="image-modal-stage" id="imageModalStage">
    <div class="image-modal-canvas" id="imageModalCanvas">
      <img class="image-modal-content" id="imageModalContent" src="" alt="" draggable="false">
    </div>
  </div>

  <div class="image-modal-toolbar" role="group" aria-label="Controale imagine">
    <button class="image-zoom-button" id="zoomOutButton" type="button" aria-label="Micșorează">
      −
    </button>

    <span class="image-zoom-level" id="zoomLevel" aria-live="polite">
      Potrivire
    </span>

    <button class="image-zoom-button" id="zoomInButton" type="button" aria-label="Mărește">
      +
    </button>

    <button class="image-zoom-reset" id="zoomResetButton" type="button">
      Potrivește
    </button>
  </div>
</div>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const modal = document.getElementById("imageModal");
    const stage = document.getElementById("imageModalStage");
    const canvas = document.getElementById("imageModalCanvas");
    const modalImage = document.getElementById("imageModalContent");

    const closeButton = document.getElementById("imageModalClose");
    const zoomInButton = document.getElementById("zoomInButton");
    const zoomOutButton = document.getElementById("zoomOutButton");
    const zoomResetButton = document.getElementById("zoomResetButton");
    const zoomLevel = document.getElementById("zoomLevel");

    const triggers = document.querySelectorAll(
      ".zoomable-image, .project-preview-button"
    );

    if (
      !modal ||
      !stage ||
      !canvas ||
      !modalImage ||
      !closeButton ||
      !zoomInButton ||
      !zoomOutButton ||
      !zoomResetButton ||
      !zoomLevel
    ) {
      console.warn("Elementele modalului pentru imagini nu au fost găsite.");
      return;
    }

    let fitScale = 1;
    let currentScale = 1;
    let maximumScale = 2;

    let lastFocusedElement = null;

    let isDragging = false;
    let hasDragged = false;

    let dragStartX = 0;
    let dragStartY = 0;
    let initialScrollLeft = 0;
    let initialScrollTop = 0;

    // --- NOU: stare pentru pinch-to-zoom pe mobil ---
    let activePointers = new Map();
    let pinchStartDistance = 0;
    let pinchStartScale = 1;
    let pinchMidpoint = {
      x: 0,
      y: 0
    };

    function clamp(value, minimum, maximum) {
      return Math.min(Math.max(value, minimum), maximum);
    }

    function isModalOpen() {
      return modal.classList.contains("is-open");
    }

    function getImageSource(trigger) {
      return (
        trigger.getAttribute("data-preview-target") ||
        trigger.getAttribute("data-full-image") ||
        trigger.getAttribute("src") ||
        ""
      );
    }

    function getImageAlt(trigger) {
      return (
        trigger.getAttribute("data-preview-alt") ||
        trigger.getAttribute("alt") ||
        "Previzualizare proiect"
      );
    }

    function calculateFitScale() {
      if (!modalImage.naturalWidth || !modalImage.naturalHeight) {
        return 1;
      }

      const isMobile = window.innerWidth <= 768;
      const horizontalSpace = isMobile ? 24 : 80;
      const verticalSpace = isMobile ? 150 : 190;

      const availableWidth = Math.max(stage.clientWidth - horizontalSpace, 200);
      const availableHeight = Math.max(stage.clientHeight - verticalSpace, 200);

      const widthScale = availableWidth / modalImage.naturalWidth;
      const heightScale = availableHeight / modalImage.naturalHeight;

      return Math.min(widthScale, heightScale, 1);
    }

    function calculateMaximumScale() {
      if (fitScale < 1) {
        return 1;
      }
      return 2;
    }

    function updateZoomLabel() {
      const relativeZoom = currentScale / Math.max(fitScale, 0.001);

      if (Math.abs(relativeZoom - 1) < 0.02) {
        zoomLevel.textContent = "Potrivire";
      } else {
        zoomLevel.textContent = Math.round(relativeZoom * 100) + "%";
      }

      zoomOutButton.disabled = currentScale <= fitScale + 0.001;
      zoomInButton.disabled = currentScale >= maximumScale - 0.001;
    }

    // NOU: activează/dezactivează tranziția smooth (o oprim în timpul dragului/pinch pentru fluiditate)
    function setTransitionEnabled(enabled) {
      modalImage.style.transition = enabled ?
        "width 0.15s ease-out, height 0.15s ease-out" :
        "none";
    }

    function updateImageSize() {
      if (!modalImage.naturalWidth || !modalImage.naturalHeight) {
        return;
      }

      const imageWidth = Math.max(Math.round(modalImage.naturalWidth * currentScale), 1);
      const imageHeight = Math.max(Math.round(modalImage.naturalHeight * currentScale), 1);

      modalImage.style.width = imageWidth + "px";
      modalImage.style.height = imageHeight + "px";
      modalImage.style.maxWidth = "none";
      modalImage.style.maxHeight = "none";
      modalImage.style.objectFit = "contain";

      canvas.style.width = Math.max(stage.clientWidth, imageWidth + 48) + "px";
      canvas.style.height = Math.max(stage.clientHeight, imageHeight + 48) + "px";
      canvas.style.minWidth = "100%";
      canvas.style.minHeight = "100%";
      canvas.style.display = "flex";
      canvas.style.alignItems = "center";
      canvas.style.justifyContent = "center";

      stage.style.overflow = currentScale > fitScale + 0.01 ? "auto" : "hidden";
      stage.classList.toggle("is-zoomed", currentScale > fitScale + 0.01);

      updateZoomLabel();
    }

    function centerImage() {
      stage.scrollLeft = Math.max((stage.scrollWidth - stage.clientWidth) / 2, 0);
      stage.scrollTop = Math.max((stage.scrollHeight - stage.clientHeight) / 2, 0);
    }

    function fitImage() {
      setTransitionEnabled(false);
      fitScale = calculateFitScale();
      maximumScale = calculateMaximumScale();
      currentScale = fitScale;

      updateImageSize();

      window.requestAnimationFrame(function () {
        centerImage();
      });
    }

    function setScale(nextScale, clientX, clientY, smooth) {
      setTransitionEnabled(smooth !== false);

      const previousScrollWidth = stage.scrollWidth;
      const previousScrollHeight = stage.scrollHeight;
      const stageRectangle = stage.getBoundingClientRect();

      const pointerX = typeof clientX === "number" ? clientX - stageRectangle.left : stage.clientWidth / 2;
      const pointerY = typeof clientY === "number" ? clientY - stageRectangle.top : stage.clientHeight / 2;

      const contentX = stage.scrollLeft + pointerX;
      const contentY = stage.scrollTop + pointerY;

      currentScale = clamp(nextScale, fitScale, maximumScale);

      updateImageSize();

      window.requestAnimationFrame(function () {
        const widthRatio = stage.scrollWidth / Math.max(previousScrollWidth, 1);
        const heightRatio = stage.scrollHeight / Math.max(previousScrollHeight, 1);

        stage.scrollLeft = contentX * widthRatio - pointerX;
        stage.scrollTop = contentY * heightRatio - pointerY;
      });
    }

    function resetModalStyles() {
      modalImage.removeAttribute("style");
      canvas.removeAttribute("style");
      stage.removeAttribute("style");

      stage.classList.remove("is-zoomed", "is-dragging");

      stage.scrollLeft = 0;
      stage.scrollTop = 0;
    }

    function openModal(trigger) {
      const source = getImageSource(trigger);
      if (!source) return;

      lastFocusedElement = trigger;
      resetModalStyles();

      zoomLevel.textContent = "Se încarcă...";

      modalImage.alt = getImageAlt(trigger);
      modalImage.src = source;

      modal.classList.add("is-open");
      modal.setAttribute("aria-hidden", "false");

      document.body.classList.add("modal-open");
      closeButton.focus();

      if (modalImage.complete && modalImage.naturalWidth) {
        window.requestAnimationFrame(fitImage);
      }
    }

    function closeModal() {
      if (!isModalOpen()) return;

      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      document.body.classList.remove("modal-open");

      isDragging = false;
      hasDragged = false;
      activePointers.clear();

      window.setTimeout(function () {
        modalImage.src = "";
        modalImage.alt = "";
        resetModalStyles();
        zoomLevel.textContent = "Potrivire";
      }, 200);

      if (lastFocusedElement && typeof lastFocusedElement.focus === "function") {
        lastFocusedElement.focus();
      }
    }

    modalImage.addEventListener("load", function () {
      window.requestAnimationFrame(fitImage);
    });

    modalImage.addEventListener("error", function () {
      zoomLevel.textContent = "Imagine indisponibilă";
    });

    triggers.forEach(function (trigger) {
      trigger.addEventListener("click", function () {
        openModal(trigger);
      });

      if (trigger.classList.contains("zoomable-image")) {
        trigger.addEventListener("keydown", function (event) {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openModal(trigger);
          }
        });
      }
    });

    zoomInButton.addEventListener("click", function () {
      setScale(currentScale * 1.25);
    });

    zoomOutButton.addEventListener("click", function () {
      setScale(currentScale / 1.25);
    });

    zoomResetButton.addEventListener("click", fitImage);

    closeButton.addEventListener("click", closeModal);

    /*
     * MODIFICAT: rotița mouse-ului face zoom direct, fără Ctrl.
     * Scroll-ul normal (pan) rămâne disponibil prin drag când imaginea e mărită.
     */
    stage.addEventListener(
      "wheel",
      function (event) {
        if (!isModalOpen()) return;

        event.preventDefault();

        const zoomMultiplier = event.deltaY < 0 ? 1.12 : 1 / 1.12;

        setScale(currentScale * zoomMultiplier, event.clientX, event.clientY, false);
      }, {
        passive: false
      }
    );

    modalImage.addEventListener("dblclick", function (event) {
      event.preventDefault();

      if (currentScale <= fitScale + 0.02) {
        setScale(maximumScale, event.clientX, event.clientY);
      } else {
        fitImage();
      }
    });

    /*
     * NOU: dublu-tap pe mobil (touchend) — echivalentul dblclick, care nu
     * există nativ pentru touch pe majoritatea browserelor mobile.
     */
    let lastTapTime = 0;
    let lastTapX = 0;
    let lastTapY = 0;

    stage.addEventListener("touchend", function (event) {
      if (!isModalOpen() || event.changedTouches.length !== 1) return;
      if (activePointers.size > 0) return; // ignoră dacă tocmai s-a terminat un pinch

      const now = Date.now();
      const touch = event.changedTouches[0];
      const dx = Math.abs(touch.clientX - lastTapX);
      const dy = Math.abs(touch.clientY - lastTapY);

      if (now - lastTapTime < 300 && dx < 30 && dy < 30) {
        event.preventDefault();

        if (currentScale <= fitScale + 0.02) {
          setScale(maximumScale, touch.clientX, touch.clientY);
        } else {
          fitImage();
        }

        lastTapTime = 0;
      } else {
        lastTapTime = now;
        lastTapX = touch.clientX;
        lastTapY = touch.clientY;
      }
    });

    /*
     * NOU: pinch-to-zoom cu 2 degete pe mobil, via Pointer Events.
     */
    function getPointersDistance() {
      const points = Array.from(activePointers.values());
      const dx = points[0].x - points[1].x;
      const dy = points[0].y - points[1].y;
      return Math.hypot(dx, dy);
    }

    function getPointersMidpoint() {
      const points = Array.from(activePointers.values());
      return {
        x: (points[0].x + points[1].x) / 2,
        y: (points[0].y + points[1].y) / 2,
      };
    }

    stage.addEventListener("pointerdown", function (event) {
      if (event.pointerType === "touch") {
        activePointers.set(event.pointerId, {
          x: event.clientX,
          y: event.clientY
        });

        if (activePointers.size === 2) {
          isDragging = false; // pinch are prioritate față de drag
          pinchStartDistance = getPointersDistance();
          pinchStartScale = currentScale;
          pinchMidpoint = getPointersMidpoint();
          setTransitionEnabled(false);
          return;
        }
      }

      if (currentScale <= fitScale + 0.01) return;
      if (event.target.closest(".image-modal-toolbar, .image-modal-close")) return;
      if (activePointers.size > 1) return;

      isDragging = true;
      hasDragged = false;

      dragStartX = event.clientX;
      dragStartY = event.clientY;

      initialScrollLeft = stage.scrollLeft;
      initialScrollTop = stage.scrollTop;

      stage.classList.add("is-dragging");

      if (typeof stage.setPointerCapture === "function") {
        stage.setPointerCapture(event.pointerId);
      }
    });

    stage.addEventListener("pointermove", function (event) {
      if (event.pointerType === "touch" && activePointers.has(event.pointerId)) {
        activePointers.set(event.pointerId, {
          x: event.clientX,
          y: event.clientY
        });

        if (activePointers.size === 2) {
          event.preventDefault();

          const newDistance = getPointersDistance();
          if (pinchStartDistance > 0) {
            const scaleFactor = newDistance / pinchStartDistance;
            const nextScale = clamp(pinchStartScale * scaleFactor, fitScale, maximumScale);

            const stageRectangle = stage.getBoundingClientRect();
            setScale(
              nextScale,
              pinchMidpoint.x - stageRectangle.left + stageRectangle.left,
              pinchMidpoint.y - stageRectangle.top + stageRectangle.top,
              false
            );
          }
          return;
        }
      }

      if (!isDragging) return;

      const distanceX = event.clientX - dragStartX;
      const distanceY = event.clientY - dragStartY;

      if (Math.abs(distanceX) > 3 || Math.abs(distanceY) > 3) {
        hasDragged = true;
      }

      stage.scrollLeft = initialScrollLeft - distanceX;
      stage.scrollTop = initialScrollTop - distanceY;
    });

    function stopDragging(event) {
      if (event.pointerType === "touch") {
        activePointers.delete(event.pointerId);
        if (activePointers.size < 2) {
          pinchStartDistance = 0;
        }
      }

      if (!isDragging) return;

      isDragging = false;
      stage.classList.remove("is-dragging");

      if (
        event.pointerId !== undefined &&
        typeof stage.hasPointerCapture === "function" &&
        stage.hasPointerCapture(event.pointerId)
      ) {
        stage.releasePointerCapture(event.pointerId);
      }
    }

    stage.addEventListener("pointerup", stopDragging);
    stage.addEventListener("pointercancel", stopDragging);

    modal.addEventListener("click", function (event) {
      if (event.target === modal) {
        closeModal();
      }
    });

    stage.addEventListener("click", function (event) {
      if (hasDragged) {
        hasDragged = false;
        return;
      }

      if (event.target === stage || event.target === canvas) {
        closeModal();
      }
    });

    document.addEventListener("keydown", function (event) {
      if (!isModalOpen()) return;

      if (event.key === "Escape") {
        closeModal();
        return;
      }

      if (event.key === "+" || event.key === "=") {
        event.preventDefault();
        setScale(currentScale * 1.25);
      }

      if (event.key === "-") {
        event.preventDefault();
        setScale(currentScale / 1.25);
      }

      if (event.key === "0") {
        event.preventDefault();
        fitImage();
      }
    });

    let resizeTimer = null;

    window.addEventListener("resize", function () {
      window.clearTimeout(resizeTimer);

      resizeTimer = window.setTimeout(function () {
        if (isModalOpen()) {
          fitImage();
        }
      }, 120);
    });
  });
</script>

