<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main>
  <section class="hero section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow"><%= content.hero.eyebrow %></p>
        <h1><%= content.hero.title %></h1>
        <p class="hero-text"><%= content.hero.text %></p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="/contact#formular"><%= content.hero.primary %></a>
          <a class="btn btn-secondary" href="/servicii"><%= content.hero.secondary %></a>
        </div>

        <p class="domain-note">
          Domeniu standard inclus în pachetele de site. Domeniile premium, găzduirea premium,
          emailul profesional și aplicațiile terțe se taxează separat.
        </p>
      </div>

      <div class="hero-card" aria-label="Previzualizare panou privat">
        <div class="mini-bar"><span></span><span></span><span></span></div>
        <h2>Panou privat</h2>
        <div class="lead-row"><strong>Cereri noi</strong><span>Contactat</span></div>
        <div class="lead-row"><strong>Recenzie video</strong><span>Aprobat</span></div>
        <div class="lead-row"><strong>Programare</strong><span>10:30</span></div>
        <div class="pulse-card">+ cereri salvate direct în sistem</div>
      </div>
    </div>
  </section>

  <section class="stats-section">
    <div class="container stats-grid">
      <% content.trustStats.forEach((stat) => { %>
      <div class="stat-card">
        <strong><%= stat.value %></strong>
        <span><%= stat.label %></span>
      </div>
      <% }) %>
    </div>
  </section>

  <section id="ce-rezolam" class="section">
    <div class="container section-heading">
      <p class="eyebrow">Ce reparăm și ce facem</p>
      <h2>Problemele reale care opresc clienții din a te contacta</h2>
      <p>
        Un site bun nu este doar design. Este un sistem care explică, convinge,
        colectează cereri și transmite încredere.
      </p>
    </div>

    <div class="container cards-grid three">
      <% content.fixes.slice(0, 6).forEach((item) => { %>
      <article class="service-card equal-card">
        <h3><%= item.title %></h3>
        <p><%= item.text %></p>
      </article>
      <% }) %>
    </div>
  </section>

  <section id="pachete" class="section soft-section">
    <div class="container section-heading">
      <p class="eyebrow">Pachete principale</p>
      <h2>Alege nivelul potrivit pentru afacerea ta</h2>
      <p>
        Pe homepage păstrăm doar prezentarea scurtă. Detaliile complete, ce este inclus
        și ce nu este inclus sunt pe pagina de servicii.
      </p>
    </div>

    <div class="container-bgg pricing-grid compact-pricing-grid">
      <% content.packages.forEach((pkg) => { %>
      <article class="pricing-card equal-card <%= pkg.featured ? 'featured' : '' %>">
        <span class="pricing-tag"><%= pkg.tag %></span>
        <h3><%= pkg.name %></h3>
        <div class="price"><%= pkg.price %></div>
        <p class="intro-price"><%= pkg.introPrice %></p>
        <p><%= pkg.bestFor %></p>
        <p class="pages"><%= pkg.pages %></p>

        <h4>Pe scurt</h4>
        <ul>
          <% pkg.included.slice(0, 4).forEach((feature) => { %>
          <li><%= feature %></li>
          <% }) %>
        </ul>

        <a class="btn btn-primary full" href="/servicii">
          Vezi detalii pachet
        </a>
      </article>
      <% }) %>
    </div>

    <div class="container center-button">
      <a class="btn btn-secondary" href="/servicii">
        Vezi toate serviciile și detaliile complete
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Servicii extra</p>
      <h2>După lansare poți continua cu mentenanță sau promovare</h2>
      <p>
        Nu încărcăm homepage-ul cu toate detaliile. Fiecare serviciu are pagina lui separată.
      </p>
    </div>

    <div class="container home-service-grid">
      <article class="home-service-card">
        <span class="pricing-tag">De la 49 €/lună</span>
        <h3>Mentenanță lunară</h3>
        <p>
          Verificări, backup, suport și modificări simple după lansarea site-ului.
          Potrivit pentru afaceri care vor un site actualizat și funcțional.
        </p>
        <a class="btn btn-secondary full" href="/mentenanta">
          Vezi pachetele de mentenanță
        </a>
      </article>

      <article class="home-service-card">
        <span class="pricing-tag">De la 199 €/lună</span>
        <h3>Campanii publicitare</h3>
        <p>
          Promovare pe Facebook, Instagram și Google pentru afaceri locale.
          Bugetul efectiv de reclame se plătește separat.
        </p>
        <a class="btn btn-secondary full" href="/campanii-publicitare">
          Vezi pachetele de promovare
        </a>
      </article>
    </div>
  </section>

  <section id="proiecte" class="section projects-section">
    <div class="container section-heading">
      <p class="eyebrow">Proiecte</p>
      <h2>Exemple de proiecte create</h2>
      <p>
        Câteva exemple vizuale care arată stilul, structura și nivelul de prezentare
        pe care îl putem construi pentru afaceri locale.
      </p>
    </div>

    <div class="container projects-grid">
      <article class="project-card">
        <div class="project-image-wrap">
          <img src="/images/projects/estatepoint-hero.png"
            alt="Proiect EstatePoint - secțiune principală website imobiliare" class="project-image" loading="lazy">
          <span class="project-badge">Website imobiliare</span>
        </div>

        <div class="project-content">
          <div class="project-meta">
            <span>Design premium</span>
            <span>Responsive</span>
            <span>Lead generation</span>
          </div>

          <h3>EstatePoint — pagină principală</h3>
          <p>
            Concept modern pentru un website imobiliar, cu imagine puternică,
            structură clară și formular de căutare integrat.
          </p>

          <div class="project-actions">
            <a class="btn btn-primary" href="/contact#formular">Vreau un site similar</a>
            <a class="btn btn-secondary" href="/proiecte">Vezi proiectele</a>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-image-wrap">
          <img src="/images/projects/estatepoint-properties.png"
            alt="Proiect EstatePoint - secțiune listare proprietăți" class="project-image" loading="lazy">
          <span class="project-badge">Listare proprietăți</span>
        </div>

        <div class="project-content">
          <div class="project-meta">
            <span>UI curat</span>
            <span>Carduri elegante</span>
            <span>Experiență clară</span>
          </div>

          <h3>EstatePoint — secțiune proprietăți</h3>
          <p>
            Secțiune de prezentare pentru proprietăți premium, construită cu accent
            pe imagini mari și informații ușor de parcurs.
          </p>

          <div class="project-actions">
            <a class="btn btn-primary" href="/contact#formular">Vreau un proiect similar</a>
            <a class="btn btn-secondary" href="/proiecte">Vezi proiectele</a>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-image-wrap">
          <img src="/images/projects/devportfolio-hero.png" alt="Proiect DevPortfolio - website portofoliu developer"
            class="project-image" loading="lazy">
          <span class="project-badge">Portofoliu developer</span>
        </div>

        <div class="project-content">
          <div class="project-meta">
            <span>Look modern</span>
            <span>Personal branding</span>
            <span>UI premium</span>
          </div>

          <h3>DevPortfolio — landing page modernă</h3>
          <p>
            Concept de portofoliu cu design futurist, call to action clar și prezentare
            vizuală memorabilă.
          </p>

          <div class="project-actions">
            <a class="btn btn-primary" href="/contact#formular">Vreau un portofoliu similar</a>
            <a class="btn btn-secondary" href="/proiecte">Vezi proiectele</a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container section-heading">
      <p class="eyebrow">Cum lucrăm</p>
      <h2>Proces scurt, clar și ușor de urmărit</h2>
      <p>
        Fără întâlniri inutile și fără haos. Stabilim ce trebuie făcut, construim,
        testăm și lansăm.
      </p>
    </div>

    <div class="container cards-grid three">
      <% content.process.forEach((item) => { %>
      <article class="process-card equal-card">
        <span class="step"><%= item.step %></span>
        <h3><%= item.title %></h3>
        <p><%= item.text %></p>
      </article>
      <% }) %>
    </div>
  </section>

  <section id="faq" class="section faq-section">
    <div class="container section-heading">
      <p class="eyebrow">Întrebări frecvente</p>
      <h2>Întrebări importante înainte să începem</h2>
      <p>
        Răspunsuri scurte la cele mai comune întrebări despre site-uri, domeniu,
        mentenanță, reclame și plată.
      </p>
    </div>

    <div class="container faq-wrap">
      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>Cât durează realizarea unui site?</span>
          <strong>+</strong>
        </button>
        <div class="faq-answer">
          <p>
            Depinde de pachet, numărul de pagini și cât de repede sunt oferite materialele.
            Un site simplu poate fi livrat mai repede, iar un sistem cu programări poate dura mai mult.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>Domeniul este inclus?</span>
          <strong>+</strong>
        </button>
        <div class="faq-answer">
          <p>
            Da, un domeniu standard este inclus în pachetele de site, dacă este disponibil la un cost rezonabil.
            Domeniile premium sau foarte scumpe se taxează separat.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>Campaniile includ bugetul de reclame?</span>
          <strong>+</strong>
        </button>
        <div class="faq-answer">
          <p>
            Nu. Taxa de administrare este separată de bugetul efectiv de reclame,
            care se plătește către Facebook, Instagram sau Google.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <button class="faq-question" type="button">
          <span>Garantezi vânzări sau rezultate?</span>
          <strong>+</strong>
        </button>
        <div class="faq-answer">
          <p>
            Nu garantăm vânzări, profit, clienți sau poziții fixe pe Google.
            Rezultatele depind de ofertă, piață, buget, reputație și concurență.
          </p>
        </div>
      </div>
    </div>

    <div class="container center-button">
      <a class="btn btn-secondary" href="/servicii">
        Vezi detaliile complete
      </a>
    </div>
  </section>

  <section class="section soft-section">
    <div class="container section-heading">
      <p class="eyebrow">Blog SEO</p>
      <h2>Articole care educă piața și ajută Google să înțeleagă ce faci</h2>
    </div>

    <div class="container blog-grid">
      <% posts.slice(0, 3).forEach((post) => { %>
      <article class="blog-card equal-card">
        <% if (post.coverImage) { %>
        <img src="<%= post.coverImage %>" alt="<%= post.coverAlt || post.title %>" loading="lazy">
        <% } %>

        <div>
          <h3><%= post.title %></h3>
          <p><%= post.excerpt %></p>
        </div>

        <a class="card-link" href="/blog/<%= post.slug %>">Citește articolul</a>
      </article>
      <% }) %>
    </div>

    <div class="container center-button">
      <a class="btn btn-secondary" href="/blog">Vezi toate articolele</a>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container final-card">
      <h2>Vrei un site care colectează cereri, nu doar complimente?</h2>
      <p>Trimite detaliile afacerii tale și îți arătăm cum ar putea arăta sistemul tău.</p>
      <a class="btn btn-primary cta-small-btn" href="/contact#formular">
        Programează o consultație gratuită
      </a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>