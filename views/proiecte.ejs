<%- include('partials/head') %>
<%- include('partials/header') %>
<%- include('partials/flash') %>

<main>
    <section class="page-hero section">
        <div class="container narrow">
            <p class="eyebrow">Proiecte</p>
            <h1>Exemple de proiecte create pentru prezentare, portofoliu și conversie</h1>
            <p>
                Exemple vizuale care arată direcția de design, structura paginilor și modul
                în care putem prezenta mai clar o afacere online.
            </p>
        </div>
    </section>

    <section class="section projects-section">
        <div class="container projects-grid">
            <article class="project-card">
                <div class="project-image-wrap">
                    <img src="/images/projects/estatepoint-hero.png"
                        alt="Proiect EstatePoint - secțiune principală website imobiliare" class="project-image"
                        loading="lazy">
                    <span class="project-badge">Website imobiliare</span>
                </div>

                <div class="project-content">
                    <div class="project-meta">
                        <span>Design premium</span>
                        <span>Responsive</span>
                        <span>Lead generation</span>
                    </div>

                    <h3>EstatePoint — pagină principală</h3>
                    <p>
                        Concept modern pentru un website imobiliar, cu imagine puternică,
                        structură clară, meniu aerisit și formular de căutare integrat direct
                        în prima secțiune.
                    </p>

                    <ul class="project-features">
                        <li>Secțiune hero puternică</li>
                        <li>Formular de căutare proprietăți</li>
                        <li>Buton clar de contact</li>
                        <li>Aspect premium și profesionist</li>
                    </ul>

                    <div class="project-actions">
                        <a class="btn btn-primary" href="/contact#formular">Vreau un site similar</a>
                        <a class="btn btn-secondary" href="/servicii">Vezi serviciile</a>
                    </div>
                </div>
            </article>

            <article class="project-card">
                <div class="project-image-wrap">
                    <img src="/images/projects/estatepoint-properties.png"
                        alt="Proiect EstatePoint - secțiune listare proprietăți" class="project-image" loading="lazy">
                    <span class="project-badge">Listare proprietăți</span>
                </div>

                <div class="project-content">
                    <div class="project-meta">
                        <span>UI curat</span>
                        <span>Carduri elegante</span>
                        <span>Experiență clară</span>
                    </div>

                    <h3>EstatePoint — secțiune proprietăți</h3>
                    <p>
                        Secțiune de prezentare pentru proprietăți premium, construită cu accent
                        pe imagini mari, carduri curate și informații ușor de parcurs pentru vizitatori.
                    </p>

                    <ul class="project-features">
                        <li>Carduri elegante pentru proprietăți</li>
                        <li>Accent pe imagini și locație</li>
                        <li>Structură clară pentru descriere</li>
                        <li>Potrivit pentru agenții și dezvoltatori</li>
                    </ul>

                    <div class="project-actions">
                        <a class="btn btn-primary" href="/contact#formular">Vreau un proiect similar</a>
                        <a class="btn btn-secondary" href="/servicii">Vezi serviciile</a>
                    </div>
                </div>
            </article>

            <article class="project-card">
                <div class="project-image-wrap">
                    <img src="/images/projects/devportfolio-hero.png"
                        alt="Proiect DevPortfolio - website portofoliu developer" class="project-image" loading="lazy">
                    <span class="project-badge">Portofoliu developer</span>
                </div>

                <div class="project-content">
                    <div class="project-meta">
                        <span>Look modern</span>
                        <span>Personal branding</span>
                        <span>UI premium</span>
                    </div>

                    <h3>DevPortfolio — landing page modernă</h3>
                    <p>
                        Concept de portofoliu pentru developer, cu design futurist, fundal
                        puternic, call to action clar și prezentare vizuală memorabilă.
                    </p>

                    <ul class="project-features">
                        <li>Hero section cu impact vizual puternic</li>
                        <li>Navigație curată și modernă</li>
                        <li>Butoane clare pentru proiecte și contact</li>
                        <li>Potrivit pentru portofoliu personal sau CV online</li>
                    </ul>

                    <div class="project-actions">
                        <a class="btn btn-primary" href="/contact#formular">Vreau un portofoliu similar</a>
                        <a class="btn btn-secondary" href="/servicii">Vezi serviciile</a>
                    </div>
                </div>
            </article>
        </div>
    </section>
</main>

<%- include('partials/footer') %>